{
  "name": "vite-react-typescript-starter",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "prebuild": "node scripts/generate-sitemap.mjs --base=${SITEMAP_BASE_URL:-https://harypictures.netlify.app}",
    "build": "vite build && node -e \"const fs=require('fs'),path=require('path');const files=['robots.txt','sitemap.xml','_headers','_redirects'];const src='public',dst='dist';fs.mkdirSync(dst,{recursive:true});for(const f of files){const s=path.join(src,f),d=path.join(dst,f);if(fs.existsSync(s)){fs.copyFileSync(s,d);}}\"",
    "postbuild": "node scripts/prerender.mjs",
    "lint": "eslint .",
    "preview": "vite preview",
    "sitemap": "node scripts/generate-sitemap.mjs --base=${SITEMAP_BASE_URL:-https://harypictures.netlify.app}"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.57.0",
    "lucide-react": "^0.344.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.8.2",
    "yet-another-react-lightbox": "^3.24.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.9.1",
    "@netlify/functions": "^4.2.5",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.18",
    "eslint": "^9.9.1",
    "eslint-plugin-react-hooks": "^5.1.0-rc.0",
    "eslint-plugin-react-refresh": "^0.4.11",
    "globals": "^15.9.0",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.3.0",
    "vite": "^5.4.2",
    "puppeteer": "^23.6.0",
    "mime-types": "^2.1.35"
  }
}
